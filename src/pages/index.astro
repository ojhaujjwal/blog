---
import { getCollection } from "astro:content";
import getSortedPosts from "@utils/getSortedPosts";
import PostDetails from "@layouts/PostDetails.astro";
import Card from "@components/Card";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);

const featured = sortedPosts.find(p => p.data.featured);
const remaining = sortedPosts.filter(p => p.slug !== featured?.slug);
---

{
  featured && (
    <PostDetails post={featured} posts={sortedPosts} />
  )
}

<hr class="my-8 border-dashed" />

<section class="mx-auto w-full max-w-3xl px-4 pb-12">
  <h2 class="mb-6 text-xl font-semibold text-skin-accent">All Posts</h2>
  <ul>
    {
      remaining.map(({ data, slug }) => (
        <li class="my-6">
          <Card href={`/blog/${slug}/`} frontmatter={data} />
        </li>
      ))
    }
  </ul>
</section>
